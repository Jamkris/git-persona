{
	"name": "git-env-manager",
	"version": "1.2.4",
	"description": "Multi-git-profile manager with SSH key integration",
	"type": "module",
	"bin": {
		"ghem": "./dist/index.js",
		"git-env-manager": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"git",
		"profile",
		"ssh",
		"env-manager",
		"multi-account"
	],
	"author": "Jamkris",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Jamkris/git-env-manager"
	},
	"bugs": {
		"url": "https://github.com/Jamkris/git-env-manager/issues"
	},
	"homepage": "https://github.com/Jamkris/git-env-manager#readme",
	"dependencies": {
		"@inquirer/prompts": "^8.4.1",
		"chalk": "^5.6.2",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.3"
	}
}
